[layer_names]

2d_physics/layer_1="Impassable"
2d_physics/layer_2="Platform"
2d_physics/layer_3="Player"
2d_physics/layer_4="Enemy"
2d_physics/layer_5="Interactable"
2d_physics/layer_6="Projectile"
2d_physics/layer_7="PlayerHitbox"
2d_physics/layer_8="EnemyHitbox"
2d_physics/layer_9="CameraArea"

[physics]

common/enable_pause_aware_picking=true

[rendering]

quality/driver/driver_name="GLES2"
vram_compression/import_etc=true
vram_compression/import_etc2=false
environment/default_clear_color=Color( 0.0705882, 0.0392157, 0.101961, 1 )
environment/default_environment="res://default_env.tres"
