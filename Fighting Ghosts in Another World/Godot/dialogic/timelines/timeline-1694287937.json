			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "I know a many things...\nI am a goddess after all."
		},
		{
			"animation": "1-fade_in.gd",
			"animation_length": 1,
			"change_mirror_portrait": false,
			"change_z_index": false,
			"character": "character-1694288070.json",
