			"portrait": "(Don't change)",
			"text": "Magical powers!"
		},
		{
			"character": "character-1694288070.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Does that reaction mean are you accepting my offer?"
		},
		{
			"character": "character-1694287632.json",
